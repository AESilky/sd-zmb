{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Make (current dir)",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "Assemble (current file)",
            "type": "shell",
            "command": "uasz80",
            "args": [
                "-vl", "${filename}"
            ],
            "group": "build",
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "Make Clean (current dir)",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "Make Common",
            "type": "shell",
            "command": "make",
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}/fw"
            }
        },
        {
            "label": "Make ROM (from current dir)",
            "dependsOrder": "sequence",
            "command": "make",
            "args": [
                "ROM"
            ],
            "group": "build",
            "options": {
                "cwd": "${fileDirname}"
            }
        }
    ]
}